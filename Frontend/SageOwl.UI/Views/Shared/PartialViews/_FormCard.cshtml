@model SageOwl.UI.ViewModels.Forms.FormViewModel

<div class="form_card">
    <p class="form_card_title">@Model.Title</p>
    <p class="form_card_deadline">Deadline: @Model.Deadline</p>

    <div class="form_card_button_container">
        @if (Model.IsAdmin)
        {
            <button class="form_card_button">Edit</button>
            <button class="form_card_button">Results</button>
        }
        else
        {
            <button class="form_card_button">Start</button>
        }
    </div>
</div>
