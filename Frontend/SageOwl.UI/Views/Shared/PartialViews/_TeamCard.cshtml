@using SageOwl.UI.ViewModels
@using SageOwl.UI.ViewModels.Teams
@model TeamCardViewModel

<div class="team_card" onclick='location.href="@Url.Action("MainPage", "Team", new { teamId = Model.TeamId })"'>
    <div class="team_card_header">
        <p class="team_card_name">@Model.Name</p>
        <p class="team_card_description">
            Lorem ipsum dolor sit amet, consectetur adipiscing elit, 
            sed do eiusmod tempor incididunt ut labore et dolore magna aliqua...
        </p>
    </div>
    <div class="team_card_icons">
        <i class="fas fa-bullhorn" onclick="event.stopPropagation(); location.href='@Url.Action("Announcements", "Team", new { teamId = Model.TeamId })'"></i>
        <i class="fas fa-file-alt" onclick="event.stopPropagation(); location.href='@Url.Action("Forms", "Team", new { teamId = Model.TeamId })'"></i>
    </div>
</div>
